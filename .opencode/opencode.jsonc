{
  "$schema": "https://opencode.ai/config.json",
  // Router offline aditivo: tier minimal en T1 + reglas añaden tools desde el registro completo; max_tools 100.
  // wire-tier: packages/opencode/src/session/wire-tier.ts
  "default_agent": "build",
  "skills": {
    "paths": ["gentle-ai/skills"],
  },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
  "agent": {
    "sdd-orchestrator": {
      "mode": "primary",
      "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
      "prompt": "{file:../gentle-ai/AGENTS.md}",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-*": "allow",
        },
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": "allow",
      },
    },
    // Subagent prompts: packages/opencode/src/agent/prompt/sdd-*.txt (same as built-in defaults)
    "sdd-init": {
      "mode": "subagent",
      "hidden": true,
      "description": "Bootstrap SDD context and project configuration",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-init.txt}",
    },
    "sdd-explore": {
      "mode": "subagent",
      "hidden": true,
      "description": "Investigate codebase and think through ideas",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-explore.txt}",
    },
    "sdd-propose": {
      "mode": "subagent",
      "hidden": true,
      "description": "Create change proposals from explorations",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-propose.txt}",
    },
    "sdd-spec": {
      "mode": "subagent",
      "hidden": true,
      "description": "Write detailed specifications from proposals",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-spec.txt}",
    },
    "sdd-design": {
      "mode": "subagent",
      "hidden": true,
      "description": "Create technical design from proposals",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-design.txt}",
    },
    "sdd-tasks": {
      "mode": "subagent",
      "hidden": true,
      "description": "Break down specs and designs into implementation tasks",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-tasks.txt}",
    },
    "sdd-apply": {
      "mode": "subagent",
      "hidden": true,
      "description": "Implement code changes from task definitions",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-apply.txt}",
    },
    "sdd-verify": {
      "mode": "subagent",
      "hidden": true,
      "description": "Validate implementation against specs",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-verify.txt}",
    },
    "sdd-archive": {
      "mode": "subagent",
      "hidden": true,
      "description": "Archive completed change artifacts",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-archive.txt}",
    },
  },
  "experimental": {
    "initial_tool_tier": "minimal",
    // true → logs debug-request (toolsBytes, systemBytes, promptBytes)
    "debug_request": false,
    "tool_router": {
      "enabled": true,
      "mode": "rules",
      "additive": true,
      "apply_after_first_assistant": true,
      "inject_prompt": true,
      "base_tools": ["read", "task", "skill", "grep", "glob"],
      "max_tools": 100,
      "no_match_fallback": true,
      "no_match_fallback_tools": ["glob", "grep", "read", "task"],
      "mcp_always_include": true,
      "fallback": {
        "max_expansions_per_turn": 1,
        "expand_to": "full"
      }
    },
  },
}
