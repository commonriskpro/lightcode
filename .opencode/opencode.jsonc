{
  "$schema": "https://opencode.ai/config.json",
  // Perfil prueba: router híbrido (intención + embed Xenova + keyword_rules). El LLM solo recibe defs de tools que el router adjunta.
  // Arranque: ./scripts/opencode-isolated.sh desde la raíz del repo (tras build). Logs wire: debug_request + OPENCODE_DEBUG_REQUEST opcional.
  // Modelo: elige proveedor en la TUI; lmstudio abajo es ejemplo (cambia baseURL a tu LAN).
  "plugin": [
    "../gentle-ai/plugins/skill-registry-plugin.ts",
    "../gentle-ai/plugins/background-agents.ts",
    "opencode-lmstudio@latest",
  ],
  // build = write/edit/bash para probar tareas directas; sdd-orchestrator = delegar con task→sdd-*.
  "default_agent": "build",
  "skills": {
    "paths": ["gentle-ai/skills"],
  },
  "provider": {
    "opencode": {
      "options": {},
    },
    // LM Studio en red local (servidor OpenAI-compatible en :1234)
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (LAN)",
      "options": {
        "baseURL": "http://192.168.1.183:1234/v1",
      },
    },
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  // Engram: memoria persistente (mem_save, mem_search, …). Requiere `engram` en PATH.
  // Context7: docs actuales de librerías (resolve-library-id, query-docs). Requiere Node/npx; opcional CONTEXT7_API_KEY en el entorno.
  // Guías: docs/engram-opencode.md, docs/context7-opencode.md
  "mcp": {
    "engram": {
      "type": "local",
      "command": ["engram", "mcp"],
      "enabled": false,
      "timeout": 30000,
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": false,
      "timeout": 60000,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
    "delegate": false,
    "delegation_read": false,
    "delegation_list": false,
  },
  "agent": {
    // compact_strategy explicit|smart + compact_prompt: guía corta uniforme (Role/Goal/Use/Guardrails).
    // defer_heavy_prompt (sdd-*): en tier no-full omite el prompt largo; carga con read/skill cuando haga falta.
    "build": {
      "mode": "primary",
      "prompt": "When delegation helps, use the task tool and prefer agent \"explore\" for repository exploration and information gathering. Do not emit textual <invoke name=\"delegate\"> blocks.",
      "options": {
        "compact_strategy": "explicit",
        "compact_prompt": "Role: Primary coding assistant for this workspace.\nGoal: Solve the user request end-to-end with minimal tool/context cost.\nUse: Prefer direct tools first; delegate with task->explore only when broader investigation is needed.\nGuardrails: Do not invent capabilities; if tools are missing, state it and propose the minimal next action.",
      },
    },
    "sdd-orchestrator": {
      "mode": "primary",
      "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
      "prompt": "{file:../gentle-ai/AGENTS.md}",
      "options": {
        "defer_heavy_prompt": true,
        "compact_strategy": "explicit",
        "compact_prompt": "Role: SDD coordinator; orchestrates work across sdd-* subagents.\nGoal: Convert user intent into propose/spec/design/tasks/apply/verify/archive flow.\nUse: Delegate via task to sdd-* agents; keep orchestration state and handoffs clear.\nGuardrails: Do not implement inline unless explicitly required; load heavy SDD docs only when needed.",
      },
      // Full tool surface: overrides global `tools: { … false }` and defaults (question/plan) via last rules in merge order.
      "permission": {
        "task": {
          "*": "deny",
          "sdd-*": "allow",
        },
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "edit": "allow",
        "write": "allow",
        "apply_patch": "allow",
        "multiedit": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "codesearch": "allow",
        "question": "allow",
        "plan_enter": "allow",
        "plan_exit": "allow",
        "batch": "allow",
        "lsp": "allow",
        "delegate": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",
        "github-triage": "allow",
        "github-pr-search": "allow",
      },
    },
    // Subagent prompts: packages/opencode/src/agent/prompt/sdd-*.txt (same as built-in defaults)
    "sdd-init": {
      "mode": "subagent",
      "hidden": true,
      "description": "Bootstrap SDD context and project configuration",
      "prompt": "{file:../packages/opencode/src/agent/prompt/sdd-init.txt}",
      "options": {
        "defer_heavy_prompt": true,
        "compact_strategy": "explicit",
        "compact_prompt": "Role: SDD subagent (sdd-init) specialized for one phase.\nGoal: Complete only this phase output with high signal and low token usage.\nUse: Execute phase-specific actions; read referenced heavy docs/files only on demand.\nGuardrails: Stay in scope for sdd-init; avoid cross-phase drift and unnecessary tool calls.",
      },
      "permission": {
        "task": "allow",
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "edit": "allow",
        "write": "allow",
        "apply_patch": "allow",
        "multiedit": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "websearch": "allow",
