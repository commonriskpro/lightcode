  "experimental": {
    // true → logs service=debug-request phase=wire (toolsBytes, systemBytes, promptBytes) y phase=usage
    "debug_request": true,
    "always_include_env": true,
    "always_include_env_minimal": true,
    "tool_router": {
      "enabled": true,
      "apply_hard_gates": false,
      // Sin no_match_fallback: solo tools que elijan intent/embed/reglas/sticky/fallback vacío (probar efectividad del router).
      "router_only": false,
      "no_match_fallback": false,
      // hybrid: solo Xenova tool↔mensaje (local_embed). Sin prototipos de intención (local_intent_embed false). keyword_rules false = sin regex RULES.
      "mode": "hybrid",
      "keyword_rules": false,
      "local_embed": true,
      "local_intent_embed": false,
      "local_embed_model": "Xenova/paraphrase-multilingual-MiniLM-L12-v2",
      // Xenova: más herramientas pasan el corte (bajar min, bajar ratio = más candidatos vs el mejor score, subir budget).
      // Si hay ruido, sube local_embed_min_score (p. ej. 0.22) o auto_score_ratio (p. ej. 0.78).
      "auto_tool_selection": true,
      "auto_score_ratio": 0.72,
      "auto_token_budget": 2400,
      "max_tools_cap": 100,
      "local_embed_top_k": 8,
      "local_embed_min_score": 0.18,
      "additive": true,
      // true: imperativos crear/borrar (strongWrite/strongDelete) añaden write/bash al router sin depender solo del embed.
      "lexical_strong_seed": true,
      "apply_after_first_assistant": false,
      "inject_prompt": true,
      "max_tools": 100,
      "mcp_always_include": false,
      // ── Tool exposure + fallback (manual test PRIMARY profile) ─────────────────
      // Subset per turn + reminder of unlocked ids; conservative empty-selection recovery.
      "fallback": {
        "enabled": true,
        "max_expansions_per_turn": 1,
        "expand_to": "full",
        "recover_empty_without_signal": false,
      },
      // Post-router: per_turn_subset | memory_only_unlocked | subset_plus_memory_reminder | session_accumulative_callable | stable_catalog_subset (docs/router-eval.md).
      "exposure_mode": "session_accumulative_callable",
      // "exposure_mode": "subset_plus_memory_reminder",
    },
  },
}
