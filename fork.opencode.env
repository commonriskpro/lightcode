# fork.opencode.env — variables de entorno del fork (Lightcode / offline + portable)
# Cargar desde la raíz del repo:
#   set -a && source ./fork.opencode.env && set +a
# Luego: ./scripts/opencode-isolated.sh   o   el binario en dist/
#
# Valores booleanos típicos: 1, true, 0, false (según variable; muchas usan truthy/falsy en flag.ts)

# --- Portabilidad (árbol único: data/cache/config/state bajo una raíz) ---
# Raíz; por defecto .local-opencode en el cwd al hacer source (mejor: exportar ruta absoluta al repo).
OPENCODE_PORTABLE_ROOT="${OPENCODE_PORTABLE_ROOT:-$PWD/.local-opencode}"
# Alternativa: solo cwd/.local-opencode (sin ruta explícita)
# OPENCODE_PORTABLE=1
# No inferir <repo>/.local-opencode desde la ruta …/dist/opencode-*/bin/opencode
# OPENCODE_DISABLE_PORTABLE_INFER=1

# --- Binario a ejecutar (opcional; el script aislado rellena dist/ si existe) ---
# OPENCODE_BIN_PATH="$PWD/packages/opencode/dist/opencode-darwin-arm64/bin/opencode"

# --- Router de tools offline + tier inicial (ver docs/spec-offline-tool-router.md) ---
# OPENCODE_TOOL_ROUTER=1
# OPENCODE_INITIAL_TOOL_TIER=minimal
# OPENCODE_INITIAL_MINIMAL_INCLUDE_BASH=1

# --- Logs debug-request (wire / http / usage) ---
# OPENCODE_DEBUG_REQUEST=1

# --- Config explícita (opcional; suelen bastar project .opencode + portable) ---
# OPENCODE_CONFIG=/ruta/opencode.jsonc
# OPENCODE_CONFIG_DIR=/ruta/.opencode
# OPENCODE_CONFIG_CONTENT='{"$schema":"https://opencode.ai/config.json"}'

# --- Modelos / datos ---
# OPENCODE_MODELS_URL=
# OPENCODE_MODELS_PATH=
# OPENCODE_DB=

# --- Red / consola / auth ---
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_DISABLE_MODELS_FETCH=1

# --- Plugins / cliente / TUI ---
# OPENCODE_DISABLE_DEFAULT_PLUGINS=1
# OPENCODE_CLIENT=cli
# OPENCODE_TUI_CONFIG=
# OPENCODE_PLUGIN_META_FILE=

# --- Claude / skills externos ---
# OPENCODE_DISABLE_CLAUDE_CODE=1
# OPENCODE_DISABLE_CLAUDE_CODE_PROMPT=1
# OPENCODE_DISABLE_CLAUDE_CODE_SKILLS=1
# OPENCODE_DISABLE_EXTERNAL_SKILLS=1

# --- Experimental (ver flag.ts) ---
# OPENCODE_EXPERIMENTAL=1
# OPENCODE_EXPERIMENTAL_PLAN_MODE=1
# OPENCODE_EXPERIMENTAL_WORKSPACES=1
# OPENCODE_EXPERIMENTAL_MARKDOWN=1
# OPENCODE_EXPERIMENTAL_OXFMT=1
# OPENCODE_EXPERIMENTAL_LSP_TOOL=1
# OPENCODE_EXPERIMENTAL_LSP_TY=1
# OPENCODE_EXPERIMENTAL_BASH_DEFAULT_TIMEOUT_MS=
# OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=
# OPENCODE_EXPERIMENTAL_ICON_DISCOVERY=1
# OPENCODE_EXPERIMENTAL_FILEWATCHER=
# OPENCODE_EXPERIMENTAL_DISABLE_FILEWATCHER=
# OPENCODE_EXPERIMENTAL_DISABLE_COPY_ON_SELECT=
# OPENCODE_ENABLE_EXA=1
# OPENCODE_EXPERIMENTAL_EXA=1

# --- Otras flags ---
# OPENCODE_PURE=1
# OPENCODE_CONFIG=
# OPENCODE_DISABLE_PROJECT_CONFIG=1
# OPENCODE_DISABLE_AUTOUPDATE=1
# OPENCODE_ALWAYS_NOTIFY_UPDATE=1
# OPENCODE_DISABLE_PRUNE=1
# OPENCODE_DISABLE_TERMINAL_TITLE=1
# OPENCODE_SHOW_TTFD=1
# OPENCODE_PERMISSION=
# OPENCODE_DISABLE_LSP_DOWNLOAD=1
# OPENCODE_ENABLE_EXPERIMENTAL_MODELS=1
# OPENCODE_DISABLE_AUTOCOMPACT=1
# OPENCODE_DISABLE_EMBEDDED_WEB_UI=1
# OPENCODE_DISABLE_CHANNEL_DB=1
# OPENCODE_SKIP_MIGRATIONS=1
# OPENCODE_STRICT_CONFIG_DEPS=1
# OPENCODE_DISABLE_FILETIME_CHECK=
# OPENCODE_FAKE_VCS=
# OPENCODE_ENABLE_QUESTION_TOOL=1
# OPENCODE_GIT_BASH_PATH=

# --- Tests (no usar en producción) ---
# OPENCODE_TEST_HOME=
# OPENCODE_TEST_MANAGED_CONFIG_DIR=
