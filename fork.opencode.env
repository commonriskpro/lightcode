# fork.opencode.env
# Baseline autocontenido (cercano al comportamiento original):
# - Solo define el árbol portable.
# - No fuerza flags experimentales de router/debug/imports.
# - Si quieres ignorar este archivo por completo: OPENCODE_SKIP_FORK_ENV=1

# Árbol portable (se sustituye __REPO_ROOT__ por la raíz del repo al cargar)
OPENCODE_PORTABLE_ROOT=__REPO_ROOT__/.local-opencode

# Plugin npm installs (e.g. opencode-lmstudio): skip lifecycle scripts when native builds fail (better-sqlite3).
OPENCODE_PLUGIN_INSTALL_IGNORE_SCRIPTS=1

# Optional overrides (disabled by default):
# OPENCODE_DEBUG_REQUEST=1
# OPENCODE_TOOL_ROUTER=1
# OPENCODE_TOOL_ROUTER_MODE=hybrid
# OPENCODE_TOOL_ROUTER_ONLY=1
