# fork.opencode.env — fork Lightcode: carga automática al arrancar (global + launcher bin/opencode).
# Solo aplica variables que aún no estén definidas en el entorno.
# Desactivar: OPENCODE_SKIP_FORK_ENV=1
#
# Perfil: tier minimal + router aditivo (experimental en .opencode/opencode.jsonc).
# MCP sigue incluido vía project config; skills globales del home desactivados en portable.

# Árbol portable (sustituye __REPO_ROOT__ por la raíz del repo al cargar)
OPENCODE_PORTABLE_ROOT=__REPO_ROOT__/.local-opencode

OPENCODE_TOOL_ROUTER=1
OPENCODE_INITIAL_TOOL_TIER=minimal

# Sin inyección global de AGENTS/CLAUDE desde ~/.config y ~/.claude; sin lecturas proactivas README/CLAUDE.md/package.json
OPENCODE_DISABLE_GLOBAL_DOC_READS=1

# Menos re-ensamblado del system prompt (misma lógica; TTL más largo = menos tokens repetidos)
OPENCODE_SYSTEM_PROMPT_CACHE_MS=120000

# Opcional: incluir bash en el tier mínimo (más tokens en el 1.er turno)
# OPENCODE_INITIAL_MINIMAL_INCLUDE_BASH=1

# Debug wire: experimental.debug_request en .opencode/opencode.jsonc (true para pruebas)
# OPENCODE_DEBUG_REQUEST=1

# Engram: mismo nombre de proyecto en todas las máquinas. Heredado por subprocess `engram mcp` si no usas environment en .opencode/opencode.jsonc.
# Ver docs/engram-opencode.md
ENGRAM_PROJECT=lightcode

# Context7 (docs de librerías vía MCP). Opcional; sube límites: https://context7.com/dashboard
# CONTEXT7_API_KEY=

# SDD: perfil de modelos en .opencode/sdd-models.jsonc (sobrescribe "active" del archivo). Ver docs/multi-mode-sdd.md y /sdd-models en la TUI.
# OPENCODE_SDD_MODEL_PROFILE=quality
